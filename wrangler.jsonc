{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "philipz-fit-site",
  "compatibility_date": "2026-05-08",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "directory": "dist/public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
